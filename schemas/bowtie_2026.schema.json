{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Bowtie 2026 High-Fidelity Standard",
    "type": "object",
    "required": [
        "id",
        "type",
        "stem",
        "itemContext",
        "actions",
        "potentialConditions",
        "condition",
        "parameters",
        "rationale",
        "scoring",
        "pedagogy"
    ],
    "properties": {
        "id": {
            "type": "string"
        },
        "type": {
            "const": "bowtie"
        },
        "stem": {
            "type": "string",
            "minLength": 25,
            "maxLength": 500
        },
        "itemContext": {
            "type": "object",
            "required": [
                "patient",
                "sbar",
                "tabs"
            ],
            "properties": {
                "patient": {
                    "type": "object",
                    "required": [
                        "age",
                        "iso",
                        "allergies"
                    ]
                },
                "sbar": {
                    "type": "string"
                },
                "tabs": {
                    "type": "array"
                }
            }
        },
        "actions": {
            "type": "array",
            "minItems": 4,
            "maxItems": 4
        },
        "parameters": {
            "type": "array",
            "minItems": 4,
            "maxItems": 4
        },
        "potentialConditions": {
            "type": "array",
            "minItems": 3,
            "maxItems": 5
        },
        "rationale": {
            "type": "object",
            "required": [
                "clinicalPearls",
                "questionTrap",
                "mnemonic"
            ],
            "properties": {
                "questionTrap": {
                    "type": "object",
                    "required": [
                        "trapDescription",
                        "strategy"
                    ]
                },
                "mnemonic": {
                    "type": "object",
                    "required": [
                        "frontsideText",
                        "backsideText"
                    ]
                }
            }
        }
    }
}